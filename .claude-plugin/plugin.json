{
  "name": "mirror",
  "displayName": "Mirror",
  "version": "0.4.0",
  "description": "A live, searchable HTML workspace for your Claude Code conversations. Prints a localhost link; multi-session sidebar and full-text search over the transcripts your sessions already write. No API cost, localhost only.",
  "author": {
    "name": "Anoop Bhat"
  },
  "homepage": "https://github.com/anoopbhat44/mirror",
  "repository": "https://github.com/anoopbhat44/mirror",
  "license": "MIT",
  "keywords": ["transcript", "viewer", "html", "live", "hooks"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/server/hook_session_start.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/server/hook_stop.py\""
          }
        ]
      }
    ]
  }
}
